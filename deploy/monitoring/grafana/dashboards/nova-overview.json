{
  "annotations": { "list": [] },
  "description": "NOVA Virtual Streamer - System Overview Dashboard",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Pipeline Latency (p50/p95/p99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(nova_pipeline_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(nova_pipeline_latency_seconds_bucket[5m]))", "legendFormat": "p95" },
        { "expr": "histogram_quantile(0.99, rate(nova_pipeline_latency_seconds_bucket[5m]))", "legendFormat": "p99" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "LLM Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "rate(nova_llm_requests_total[5m])", "legendFormat": "{{model}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "reqps" }
      }
    },
    {
      "title": "LLM Latency (p50/p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.50, rate(nova_llm_latency_seconds_bucket[5m]))", "legendFormat": "p50" },
        { "expr": "histogram_quantile(0.95, rate(nova_llm_latency_seconds_bucket[5m]))", "legendFormat": "p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "TTS Latency by Backend",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(nova_tts_latency_seconds_bucket[5m]))", "legendFormat": "{{backend}} p95" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "title": "Events Published by Type",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "rate(nova_events_published_total[5m])", "legendFormat": "{{event_type}}" }
      ],
      "fieldConfig": {
        "defaults": { "unit": "eps" }
      }
    },
    {
      "title": "Events Dropped",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 16 },
      "targets": [
        { "expr": "increase(nova_events_dropped_total[1h])", "legendFormat": "Dropped/hr" }
      ]
    },
    {
      "title": "Circuit Breaker State",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 16 },
      "targets": [
        { "expr": "nova_circuit_breaker_state", "legendFormat": "{{name}}" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "CLOSED", "color": "green" }, "1": { "text": "OPEN", "color": "red" }, "2": { "text": "HALF_OPEN", "color": "yellow" } } }
          ]
        }
      }
    },
    {
      "title": "Safety Blocks",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        { "expr": "rate(nova_safety_blocks_total[5m])", "legendFormat": "{{category}}" }
      ]
    },
    {
      "title": "Active WebSocket Connections",
      "type": "gauge",
      "gridPos": { "h": 8, "w": 6, "x": 12, "y": 24 },
      "targets": [
        { "expr": "nova_active_websockets", "legendFormat": "WS" }
      ],
      "fieldConfig": {
        "defaults": { "max": 100, "min": 0 }
      }
    },
    {
      "title": "Knowledge Base Documents",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 24 },
      "targets": [
        { "expr": "nova_knowledge_documents", "legendFormat": "Documents" }
      ]
    },
    {
      "title": "EventBus Queue Depth",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "nova_eventbus_queue_depth", "legendFormat": "Queue Depth" }
      ]
    },
    {
      "title": "Working Memory Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 32 },
      "targets": [
        { "expr": "nova_memory_working_size", "legendFormat": "Entries" }
      ]
    }
  ],
  "refresh": "10s",
  "schemaVersion": 39,
  "tags": ["nova", "ai", "streamer"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "NOVA System Overview",
  "uid": "nova-overview",
  "version": 1
}
