# NOVA environment example
# Copy to .env and adjust values for your environment.

# Core
NOVA_CONFIG=nova.config.json
NOVA_PORT=8765
NOVA_DEBUG=false

# LLM
NOVA_LLM__BASE_URL=http://localhost:11434/v1
NOVA_LLM__API_KEY=ollama
NOVA_LLM__MODEL=qwen2.5:14b
NOVA_LLM__TIMEOUT=30
NOVA_LLM__MAX_TOKENS=150
NOVA_LLM__TEMPERATURE=0.85

# Voice
NOVA_VOICE__BACKEND=edge_tts
NOVA_VOICE__VOICE_ID=zh-CN-XiaoyiNeural
NOVA_VOICE__COSYVOICE2_URL=http://localhost:7860
NOVA_VOICE__GPT_SOVITS_URL=http://localhost:9880

# Character
NOVA_CHARACTER__PATH=characters/nova_default.toml

# Avatar
NOVA_AVATAR__ENABLED=false
NOVA_AVATAR__WS_PORT=8767

# Knowledge / RAG
NOVA_KNOWLEDGE__ENABLED=false
NOVA_KNOWLEDGE__EMBEDDING_BACKEND=ollama
NOVA_KNOWLEDGE__EMBEDDING_BASE_URL=http://localhost:11434
NOVA_KNOWLEDGE__EMBEDDING_MODEL=nomic-embed-text
NOVA_KNOWLEDGE__VECTOR_BACKEND=memory
NOVA_KNOWLEDGE__QDRANT_URL=http://localhost:6333

# NLU / tools / consolidation
NOVA_NLU__ENABLED=true
NOVA_TOOLS__ENABLED=true
NOVA_CONSOLIDATION__ENABLED=true

# Safety
NOVA_SAFETY__ENABLED=true
NOVA_SAFETY__SEMANTIC_CHECK_RATE=0.05

# Persistence
NOVA_PERSIST__ENABLED=false
NOVA_PERSIST__BACKEND=json
NOVA_PERSIST__BASE_DIR=data/state
NOVA_PERSIST__REDIS_URL=redis://localhost:6379

# Auth
NOVA_AUTH__ENABLED=false
NOVA_AUTH__JWT_SECRET=change-me-in-production
NOVA_AUTH__API_KEY=

# Observability
NOVA_OBSERVABILITY__METRICS_ENABLED=true
NOVA_OBSERVABILITY__TRACING_ENABLED=false
NOVA_OBSERVABILITY__LOG_LEVEL=INFO
NOVA_OBSERVABILITY__LOG_JSON=false

# Runtime hot state
NOVA_RUNTIME__INSTANCE_NAME=nova
NOVA_RUNTIME__SESSION_ID=primary
NOVA_RUNTIME__HOT_STATE_ENABLED=true
NOVA_RUNTIME__HOT_STATE_TTL_S=300
NOVA_RUNTIME__HOT_STATE_SYNC_INTERVAL_S=5
NOVA_RUNTIME__IDEMPOTENCY_TTL_S=600
NOVA_RUNTIME__EVENT_BUS_MODE=local
NOVA_RUNTIME__EVENT_BUS_BACKEND=memory
NOVA_RUNTIME__EVENT_BUS_STREAM=nova:events
NOVA_RUNTIME__EVENT_BUS_CONSUMER_GROUP=nova-workers
NOVA_RUNTIME__EVENT_BUS_CONSUMER_NAME=nova-consumer-1
NOVA_RUNTIME__EVENT_BUS_PENDING_MIN_IDLE_MS=30000
NOVA_RUNTIME__EVENT_BUS_RECLAIM_BATCH_SIZE=20
NOVA_RUNTIME__EVENT_BUS_MAX_RETRIES=5
NOVA_RUNTIME__EVENT_BUS_DLQ_STREAM=nova:events:dlq
