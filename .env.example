# ── NOVA Environment Configuration ──────────────────────────────────────────
# Copy this to .env and fill in your values.
# All variables can also be set directly in the environment.

# ── LLM Configuration ──────────────────────────────────────────────────────
NOVA_LLM_URL=http://localhost:11434/v1
NOVA_LLM_KEY=ollama
NOVA_LLM_MODEL=qwen2.5:14b

# ── Voice Configuration ────────────────────────────────────────────────────
NOVA_VOICE_BACKEND=edge_tts
NOVA_VOICE_ID=zh-CN-XiaoyiNeural

# ── Character Configuration ────────────────────────────────────────────────
NOVA_CHARACTER=

# ── Avatar Configuration ───────────────────────────────────────────────────
NOVA_AVATAR=false
NOVA_AVATAR_PORT=8767

# ── Knowledge Base Configuration ───────────────────────────────────────────
NOVA_KNOWLEDGE=false
NOVA_EMBEDDING_BACKEND=ollama
NOVA_EMBEDDING_URL=http://localhost:11434
NOVA_EMBEDDING_MODEL=nomic-embed-text
NOVA_VECTOR_BACKEND=memory
NOVA_QDRANT_URL=http://localhost:6333

# ── Server Configuration ───────────────────────────────────────────────────
NOVA_PORT=8765
NOVA_CONFIG=nova.config.json
